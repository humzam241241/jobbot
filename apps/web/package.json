{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -s ensure:deps && next dev",
    "prebuild": "node scripts/check-build.js || node scripts/check-build.ts || exit 0",
    "build": "pnpm -s ensure:deps && next build",
    "start": "next start",
    "lint": "next lint",
    "secretlint": "secretlint \"**/*\" -i node_modules -i .next -i .git -i dist -i .env -i .env.local -i *.env",
    "ensure:deps": "node -e \"const p=require('./package.json');const d=['pdf-lib','docx'];const m=d.filter(x=>!(p.dependencies&&p.dependencies[x]));if(m.length){console.log('Installing missing deps:',m.join(','));process.exitCode=0}else{console.log('deps ok')}\" || pnpm add pdf-lib docx"
  },
  "dependencies": {
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/client": "^5.10.0",
    "@types/node": "20.11.24",
    "@types/react": "18.2.61",
    "@types/react-dom": "18.2.19",
    "autoprefixer": "10.4.18",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.0",
    "googleapis": "^133.0.0",
    "lucide-react": "^0.344.0",
    "mammoth": "^1.7.0",
    "next": "14.1.1",
    "next-auth": "^4.24.6",
    "postcss": "8.4.35",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-google-drive-picker": "^1.2.2",
    "react-hot-toast": "^2.4.1",
    "pdf-lib": "^1.17.1",
    "docx": "^8.5.0",
    "tailwind-merge": "^2.2.1",
    "tailwindcss": "3.4.1",
    "typescript": "5.3.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "prisma": "^5.10.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "zod": "^3.23.8"
  }
}