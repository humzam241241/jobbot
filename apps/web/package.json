{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm -s ensure:deps && next dev",
    "prebuild": "node scripts/check-build.js || node scripts/check-build.ts || exit 0",
    "build": "pnpm -s ensure:deps && prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "secretlint": "secretlint \"**/*\" -i node_modules -i .next -i .git -i dist -i .env -i .env.local -i *.env",
    "ensure:deps": "node -e \"const p=require('./package.json');const d=['pdf-lib','docx'];const m=d.filter(x=>!(p.dependencies&&p.dependencies[x]));if(m.length){console.log('Installing missing deps:',m.join(','));process.exitCode=0}else{console.log('deps ok')}\" || pnpm add pdf-lib docx"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@google/generative-ai": "^0.24.1",
    "@heroicons/react": "^2.2.0",
    "@mozilla/readability": "^0.6.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@pdf-lib/fontkit": "^1.1.1",
    "@prisma/client": "^5.10.0",
    "@types/node": "20.11.24",
    "@types/react": "18.2.61",
    "@types/react-dom": "18.2.19",
    "autoprefixer": "10.4.18",
    "bcryptjs": "^2.4.3",
    "cheerio": "1.0.0-rc.12",
    "clsx": "^2.1.0",
    "docx": "^8.5.0",
    "googleapis": "^133.0.0",
    "jsdom": "^29.0.1",
    "json5": "^2.2.3",
    "jsonrepair": "^3.13.3",
    "jszip": "^3.10.1",
    "lodash": "^4.17.23",
    "lucide-react": "^0.344.0",
    "mammoth": "^1.7.0",
    "markdown-it": "^14.1.1",
    "marked": "^17.0.5",
    "mime": "^4.1.0",
    "next": "14.1.1",
    "next-auth": "^4.24.6",
    "openai": "^4.104.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.5.207",
    "pdfkit": "^0.15.2",
    "postcss": "8.4.35",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-dropzone": "^15.0.0",
    "react-google-drive-picker": "^1.2.2",
    "react-hot-toast": "^2.4.1",
    "@sparticuz/chromium-min": "^123.0.1",
    "puppeteer-core": "^22.0.0",
    "react-icons": "^5.5.0",
    "react-use": "^17.6.0",
    "sanitize-html": "^2.17.2",
    "stopwords-iso": "^1.1.0",
    "tailwind-merge": "^2.2.1",
    "tailwindcss": "3.4.1",
    "tesseract.js": "^7.0.0",
    "typescript": "5.3.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prisma": "^5.10.0",
    "zod": "^3.23.8"
  }
}