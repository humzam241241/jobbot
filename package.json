{
  "name": "resume-bot",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "pnpm@9.7.0",
  "scripts": {
    "dev": "pnpm --filter @app/web dev || pnpm --filter web dev || next dev",
    "build": "pnpm -r build || next build",
    "lint": "pnpm -r lint || eslint .",
    "test": "pnpm -r test || vitest"
  },
  "dependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.0.5",
    "mammoth": "^1.10.0",
    "pdf-parse": "^1.1.1",
    "ts-jest": "^29.4.1",
    "zod": "^4.0.17"
  }
}